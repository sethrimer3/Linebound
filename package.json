{
  "name": "linebound",
  "version": "0.1.0",
  "description": "Linebound — HTML/CSS/TypeScript Stickman RPG",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --sourcemap --outfile=dist/bundle.js",
